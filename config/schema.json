{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewAgentConfig",
  "type": "object",
  "properties": {
    "version": {"type": "integer"},
    "ai": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "model": {"type": "string"},
        "timeout_seconds": {"type": "integer", "minimum": 1}
      },
      "required": ["enabled", "model"]
    }
  },
  "required": ["version", "ai"]
}
